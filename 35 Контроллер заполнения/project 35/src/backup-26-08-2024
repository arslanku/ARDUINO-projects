#include <Arduino.h>
#include <Wire.h>

// #include <ServoSmooth.h>
// ServoSmooth servo;
#include <Servo.h>
Servo servo;

#include <EncButton.h>
Button btn(3);

#define POT1_PIN A2
#define POT2_PIN A3
#define SERVO_PIN 5
#define SENSOR_PIN 4

void setup()
{
  Serial.begin(9600);
  pinMode(A0, OUTPUT);
  pinMode(A4, OUTPUT);
  digitalWrite(A0, 0);
  digitalWrite(A4, 1);

  pinMode(A1, OUTPUT);
  pinMode(A5, OUTPUT);
  digitalWrite(A1, 0);
  digitalWrite(A5, 1);

  servo.attach(SERVO_PIN);
  servo.write(0);
  // servo.setSpeed(90);
  // servo.setAccel(0.2);
  // servo.setTargetDeg(0);
}

int pot1_value, pot2_value, servo_angle, servo_delay_time;
void loop()
{
  btn.tick();
  // servo.tick();

  pot1_value = analogRead(POT1_PIN);
  pot2_value = analogRead(POT2_PIN);
  servo_angle = map(pot1_value, 0, 1024, 0, 180);
  servo_delay_time = map(pot2_value, 0, 1024, 0, 10000);

  if (btn.click())
  {
    servo.write(servo_angle);
    // servo.setTargetDeg(servo_angle);
    delay(servo_delay_time);
    servo.write(0);
    // servo.setTargetDeg(0);
  }
}